# ============================================
# DATABASE SETUP - Choose ONE option below:
# ============================================

# Option 1: Local Docker (Linux/Mac)
# Run: docker-compose up -d
# Then use these values:
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=apotek_asasi
DB_SSLMODE=disable

# Option 2: Cloud Database (Windows without Docker)
# Sign up at https://neon.tech or https://supabase.com
# Then set your cloud DB connection string here:
# DB_HOST=your-cloud-host
# DB_PORT=5432
# DB_USER=your-user
# DB_PASSWORD=your-password
# DB_NAME=apotek_asasi
# DB_SSLMODE=require

# ============================================
# Server Configuration
# ============================================
SERVER_PORT=8080

# ============================================
# Database Pool Settings (optional)
# ============================================
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=300
DB_CONN_MAX_IDLE_TIME=120